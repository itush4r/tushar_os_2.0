# -----------------------------------------------------------------------------
# MongoDB Atlas
# -----------------------------------------------------------------------------
# Cluster connection string. Whitelist 0.0.0.0/0 in Atlas for Vercel.
MONGODB_URI=
# Database name (defaults to "portfolio" in code if unset).
MONGODB_DB=portfolio
# Salt for SHA-256 IP hashing. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MONGODB_URI_HASH_SALT=

# -----------------------------------------------------------------------------
# Google Gemini
# -----------------------------------------------------------------------------
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Admin auth
# -----------------------------------------------------------------------------
# Used by middleware Basic Auth on /admin/*
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Public
# -----------------------------------------------------------------------------
# Used for canonical URLs, sitemap, og:url. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://tushar-os-2-0.vercel.app
